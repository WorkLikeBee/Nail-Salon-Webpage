<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password – Fantastic Nails & Spa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar px-3" style="background-color:#4a2060">
    <span class="navbar-brand text-white fw-bold">Fantastic Nails – Admin</span>
    <div class="d-flex gap-2">
        <a href="/admin" class="btn btn-outline-light btn-sm">← Dashboard</a>
        <a href="/admin/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
</nav>

<div class="container d-flex justify-content-center align-items-center" style="min-height:calc(100vh - 56px)">
    <div class="card shadow p-4 p-md-5" style="width:100%;max-width:420px">
        <h4 class="fw-bold mb-1" style="color:#4a2060">Change Password</h4>
        <p class="text-muted small mb-4">Logged in as: <strong><%= username %></strong></p>

        <% if (error) { %>
            <div class="alert alert-danger py-2 small"><%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="alert alert-success py-2 small">Password updated successfully!</div>
        <% } %>

        <form action="/admin/change-password" method="POST">
            <div class="mb-3">
                <label class="form-label fw-semibold">Current Password</label>
                <input type="password" class="form-control" name="current_password" required autofocus>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">New Password</label>
                <input type="password" class="form-control" name="new_password" required minlength="8">
                <div class="form-text">Minimum 8 characters.</div>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Confirm New Password</label>
                <input type="password" class="form-control" name="confirm_password" required minlength="8">
            </div>
            <button type="submit" class="btn w-100 text-white fw-semibold" style="background-color:#4a2060">
                Update Password
            </button>
        </form>
    </div>
</div>

</body>
</html>
