            <img src="images/services/classic-pedicure.jpg" alt="Classic Pedicure">
            <div class="gallery-overlay">
                <span>Classic Pedicure</span>
            </div>
        </div>

        <div class="gallery-item" data-category="enhancements">
            <img src="images/services/dipping-powder.webp" alt="Dipping Powder">
            <div class="gallery-overlay">
                <span>Dipping Powder</span>
            </div>
        </div>

        <div class="gallery-item" data-category="pedicure">
            <img src="images/services/deluxe-pedicure.webp" alt="Deluxe Pedicure">
            <div class="gallery-overlay">
                <span>Classic Deluxe Pedicure</span>
            </div>
        </div>

        <div class="gallery-item" data-category="enhancements">
            <img src="images/services/acrylic-set.avif" alt="Acrylic Set">
            <div class="gallery-overlay">
                <span>Acrylic Set</span>
            </div>
        </div>

        <div class="gallery-item" data-category="pedicure">
            <img src="images/services/jelly-spa.webp" alt="Jelly Spa">
            <div class="gallery-overlay">
                <span>Relaxing Jelly Spa</span>
            </div>
        </div>

        <div class="gallery-item" data-category="manicure">
            <img src="images/services/mani-spa.jpeg" alt="Spa Manicure">
            <div class="gallery-overlay">
                <span>Spa Manicure</span>
            </div>
        </div>

        <div class="gallery-item" data-category="enhancements">
            <img src="images/services/builder-gel.webp" alt="Builder Gel">
            <div class="gallery-overlay">
                <span>Builder Gel Set</span>
            </div>
        </div>

        <div class="gallery-item" data-category="pedicure">
            <img src="images/services/detox-pedi.jpg" alt="Detox Pedicure">
            <div class="gallery-overlay">
                <span>Detox Spa Pedicure</span>
            </div>
        </div>

        <div class="gallery-item" data-category="nailart">
            <img src="images/index/Nailsmodel1.jpg" alt="Nail Art">
            <div class="gallery-overlay">
                <span>Nail Art</span>
            </div>
        </div>

        <div class="gallery-item" data-category="pedicure">
            <img src="images/index/pedicure2.jpg" alt="Pedicure">
            <div class="gallery-overlay">
                <span>Pedicure</span>
            </div>
        </div>

        <div class="gallery-item" data-category="enhancements">
            <img src="images/services/hybrid-gel.jpg" alt="Hybrid Gel">
            <div class="gallery-overlay">
                <span>Hybrid Gel</span>
            </div>
        </div>

        <div class="gallery-item" data-category="pedicure">
            <img src="images/services/organic-pedi.jpg" alt="Organic Pedicure">
            <div class="gallery-overlay">
                <span>Organic Collagen Pedicure</span>
