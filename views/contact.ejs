<%- include("partials/header.ejs") %>

<!-- Hero Banner -->
<div class="faq-hero text-center">
    <div class="faq-hero-overlay">
        <h1 class="faq-hero-title">Contact Us</h1>
        <p class="faq-hero-sub">We'd love to hear from you</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-5 justify-content-center">

        <!-- Contact Info Column -->
        <div class="col-12 col-lg-4">
            <h5 class="contact-section-heading">Get in Touch</h5>
            <p class="text-body-secondary mb-4">Have a question or want to book an appointment? Reach out and we'll get back to you as soon as possible.</p>

            <div class="contact-info-block">
                <div class="contact-info-item">
                    <div class="contact-info-icon">📍</div>
                    <div>
                        <div class="contact-info-label">Address</div>
                        <div class="contact-info-value">507B Harrison Avenue<br>Centralia, WA 98531</div>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">📞</div>
                    <div>
                        <div class="contact-info-label">Phone</div>
                        <a href="tel:+13607364123" class="contact-info-value">(360) 736-4123</a>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">🕐</div>
                    <div>
                        <div class="contact-info-label">Hours</div>
                        <div class="contact-info-value">
                            Mon – Sat: 9:30 AM – 7:00 PM<br>
                            Sun: 11:00 AM – 5:00 PM
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Form Column -->
        <div class="col-12 col-lg-6">
            <div class="contact-form-card">
                <h5 class="contact-section-heading mb-4">Send Us a Message</h5>

                <% if (locals.success === true) { %>
                    <div class="alert contact-alert-success mb-4">
                        ✅ Message sent! We'll be in touch soon.
                    </div>
                <% } %>
                <% if (locals.success === false) { %>
                    <div class="alert contact-alert-error mb-4">
                        ❌ Something went wrong. Please try again or call us directly.
                    </div>
                <% } %>

                <form action="/contact" method="POST">
                    <div class="row g-3">
                        <div class="col-12 col-sm-6">
                            <label for="name" class="contact-label">Your Name</label>
                            <input type="text" class="contact-input form-control" id="name" name="name" placeholder="Jane Doe" required>
                        </div>
                        <div class="col-12 col-sm-6">
                            <label for="phone" class="contact-label">Phone Number</label>
                            <input type="tel" class="contact-input form-control" id="phone" name="phone" placeholder="(360) 000-0000">
                        </div>
                        <div class="col-12">
                            <label for="email" class="contact-label">Email Address</label>
                            <input type="email" class="contact-input form-control" id="email" name="email" placeholder="you@example.com" required>
                        </div>
                        <div class="col-12">
                            <label for="service" class="contact-label">Service Interested In</label>
                            <select class="contact-input form-select" id="service" name="service">
                                <option value="" disabled selected>Select a service...</option>
                                <option value="Manicure">Manicure</option>
                                <option value="Pedicure">Pedicure</option>
                                <option value="Nail Enhancements">Nail Enhancements</option>
                                <option value="Waxing">Waxing</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="message" class="contact-label">Message</label>
                            <textarea class="contact-input form-control" id="message" name="message" rows="5"
                                placeholder="Tell us anything — questions, special requests, preferred date..." required></textarea>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="contact-submit-btn w-100">
                                Send Message
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

<%- include("partials/footer.ejs") %>