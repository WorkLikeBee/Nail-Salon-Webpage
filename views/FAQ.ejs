<%- include("partials/header.ejs") %>

<!-- Hero Banner -->
<div class="faq-hero text-center">
    <div class="faq-hero-overlay">
        <h1 class="faq-hero-title">Frequently Asked Questions</h1>
        <p class="faq-hero-sub">Everything you need to know before your visit</p>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">

            <!-- APPOINTMENTS -->
            <h5 class="faq-category-label">Appointments</h5>
            <div class="accordion mb-4" id="faqAppointments">

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn" type="button" data-bs-toggle="collapse" data-bs-target="#faq-a1" aria-expanded="true">
                            Do I need an appointment, or do you accept walk-ins?
                        </button>
                    </h2>
                    <div id="faq-a1" class="accordion-collapse collapse show" data-bs-parent="#faqAppointments">
                        <div class="accordion-body faq-body">
                            We welcome both walk-ins and appointments. However, booking in advance is recommended — especially on weekends — to guarantee your preferred time and nail technician.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-a2">
                            How do I book an appointment?
                        </button>
                    </h2>
                    <div id="faq-a2" class="accordion-collapse collapse" data-bs-parent="#faqAppointments">
                        <div class="accordion-body faq-body">
                            You can call us directly at <a href="tel:+13607364123">(360) 736-4123</a> to schedule your visit. We're happy to help you find the best time and service for your needs.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-a3">
                            What is your cancellation policy?
                        </button>
                    </h2>
                    <div id="faq-a3" class="accordion-collapse collapse" data-bs-parent="#faqAppointments">
                        <div class="accordion-body faq-body">
                            We kindly ask for at least <strong>24 hours' notice</strong> if you need to cancel or reschedule. This allows us to offer the slot to other clients. Late cancellations or no-shows may be subject to a fee.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-a4">
                            How early should I arrive for my appointment?
                        </button>
                    </h2>
                    <div id="faq-a4" class="accordion-collapse collapse" data-bs-parent="#faqAppointments">
                        <div class="accordion-body faq-body">
                            We recommend arriving <strong>5–10 minutes early</strong> so you have time to relax, choose your color, and get settled before your service begins.
                        </div>
                    </div>
                </div>

            </div>

            <!-- SERVICES -->
            <h5 class="faq-category-label">Services & Pricing</h5>
            <div class="accordion mb-4" id="faqServices">

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-s1">
                            What services do you offer?
                        </button>
                    </h2>
                    <div id="faq-s1" class="accordion-collapse collapse" data-bs-parent="#faqServices">
                        <div class="accordion-body faq-body">
                            We offer a full range of nail and spa services including manicures, pedicures, nail enhancements (acrylic, gel, dip powder), waxing, and more. Visit our <a href="/services">Services</a> page for the complete menu and pricing.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-s2">
                            How long do gel or acrylic nails last?
                        </button>
                    </h2>
                    <div id="faq-s2" class="accordion-collapse collapse" data-bs-parent="#faqServices">
                        <div class="accordion-body faq-body">
                            With proper care, gel nails typically last <strong>2–3 weeks</strong> and acrylic sets last <strong>2–3 weeks</strong> before needing a fill. Dip powder can last up to <strong>3–4 weeks</strong>. Results may vary depending on your lifestyle and nail care routine.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-s3">
                            Do you offer nail art and custom designs?
                        </button>
                    </h2>
                    <div id="faq-s3" class="accordion-collapse collapse" data-bs-parent="#faqServices">
                        <div class="accordion-body faq-body">
                            Yes! Our technicians are skilled in a wide variety of nail art styles — from simple accents to detailed custom designs. Feel free to bring inspiration photos and we'll do our best to bring your vision to life.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-s4">
                            What nail polish brands do you use?
                        </button>
                    </h2>
                    <div id="faq-s4" class="accordion-collapse collapse" data-bs-parent="#faqServices">
                        <div class="accordion-body faq-body">
                            We use premium, professional-grade brands including <strong>OPI, CND, DND, Chisel</strong>, and <strong>Kiara Sky</strong> to ensure long-lasting, vibrant results.
                        </div>
                    </div>
                </div>

            </div>

            <!-- HEALTH & SAFETY -->
            <h5 class="faq-category-label">Health & Safety</h5>
            <div class="accordion mb-4" id="faqSafety">

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-h1">
                            How do you ensure cleanliness and hygiene?
                        </button>
                    </h2>
                    <div id="faq-h1" class="accordion-collapse collapse" data-bs-parent="#faqSafety">
                        <div class="accordion-body faq-body">
                            Your safety is our top priority. All tools are sterilized or single-use, pedicure basins are sanitized between every client, and our technicians maintain the highest hygiene standards throughout every service.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-h2">
                            What if I have a nail infection or skin condition?
                        </button>
                    </h2>
                    <div id="faq-h2" class="accordion-collapse collapse" data-bs-parent="#faqSafety">
                        <div class="accordion-body faq-body">
                            For the safety of all our clients and staff, we may need to decline services if a fungal infection or contagious skin condition is present. We recommend consulting a doctor first and rescheduling once cleared.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-h3">
                            Are your products safe for pregnant clients?
                        </button>
                    </h2>
                    <div id="faq-h3" class="accordion-collapse collapse" data-bs-parent="#faqSafety">
                        <div class="accordion-body faq-body">
                            We use high-quality, low-toxin products and ensure good ventilation throughout our salon. We recommend consulting your doctor before any nail service during pregnancy. Please let us know and we'll take extra care to ensure your comfort and safety.
                        </div>
                    </div>
                </div>

            </div>

            <!-- GENERAL -->
            <h5 class="faq-category-label">General</h5>
            <div class="accordion mb-5" id="faqGeneral">

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-g1">
                            Where are you located?
                        </button>
                    </h2>
                    <div id="faq-g1" class="accordion-collapse collapse" data-bs-parent="#faqGeneral">
                        <div class="accordion-body faq-body">
                            We're located at <strong>507B Harrison Avenue, Centralia, WA 98531</strong>. Come visit us — we'd love to see you!
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-g2">
                            What payment methods do you accept?
                        </button>
                    </h2>
                    <div id="faq-g2" class="accordion-collapse collapse" data-bs-parent="#faqGeneral">
                        <div class="accordion-body faq-body">
                            We accept <strong>cash and major credit/debit cards</strong>. Tipping in cash is always appreciated by our technicians but not required.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-g3">
                            Do you offer gift cards?
                        </button>
                    </h2>
                    <div id="faq-g3" class="accordion-collapse collapse" data-bs-parent="#faqGeneral">
                        <div class="accordion-body faq-body">
                            Yes! Gift cards are available in-store and make a perfect present for any occasion. Call us at <a href="tel:+13607364123">(360) 736-4123</a> for more details.
                        </div>
                    </div>
                </div>

                <div class="accordion-item faq-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-g4">
                            Still have questions?
                        </button>
                    </h2>
                    <div id="faq-g4" class="accordion-collapse collapse" data-bs-parent="#faqGeneral">
                        <div class="accordion-body faq-body">
                            We're always happy to help! Give us a call at <a href="tel:+13607364123">(360) 736-4123</a> and a member of our team will be glad to answer any questions you have.
                        </div>
                    </div>
                </div>

            </div>

            <!-- CTA -->
            <div class="faq-cta text-center">
                <p class="faq-cta-text">Ready to treat yourself?</p>
                <a href="tel:+13607364123" class="btn btn-lg faq-cta-btn">📞 Book Now: (360) 736-4123</a>
            </div>

        </div>
    </div>
</div>

<%- include("partials/footer.ejs") %>
